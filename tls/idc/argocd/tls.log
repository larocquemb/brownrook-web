export INT_CA_KEY_URI='pkcs11:model=PKCS%2315%20emulated;manufacturer=piv_II;serial=bce121959172aac1;token=Brown%20Rook%20Intermediate%20CA;id=%02;object=SIGN%20key;type=private'

mkdir -p ~/Developer/brownrook/brownrook-pki/pki/intermediate/newcerts
touch ~/Developer/brownrook/brownrook-pki/pki/intermediate/index.txt
[ -f ~/Developer/brownrook/brownrook-pki/pki/intermediate/serial ] || echo 1000 > ~/Developer/brownrook/brownrook-pki/pki/intermediate/serial

openssl ca \
  -provider pkcs11 \
  -provider default \
  -config intermediate-ca.cnf \
  -cert ~/Developer/brownrook/brownrook-pki/pki/intermediate/intermediate_ca.crt \
  -keyfile "$INT_CA_KEY_URI" \
  -extensions server_cert \
  -extfile argocd-ext.cnf \
  -in argocd.brownrook.net.csr \
  -out argocd.brownrook.net.crt \
  -batch \
  -notext

cat argocd.brownrook.net.crt \
  ~/Developer/brownrook/brownrook-pki/pki/intermediate/intermediate_ca.crt \
  > argocd.brownrook.net.fullchain.crt


awk 'BEGIN{n=0} /BEGIN CERTIFICATE/{n++} {print > ("/tmp/cert" n ".pem")}' argocd.brownrook.net.fullchain.crt
openssl x509 -in /tmp/cert1.pem -noout -subject -issuer
openssl x509 -in /tmp/cert2.pem -noout -subject -issuer

